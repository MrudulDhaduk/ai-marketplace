# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: individual vars (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_marketplace
DB_USER=postgres
DB_PASSWORD=replace-me
DB_SSL=false

# Option B: connection string (production — takes precedence over individual vars)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Pool tuning (optional — safe defaults shown)
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-plus-character-random-secret
JWT_EXPIRES_IN=15m

# Refresh token secret — use a DIFFERENT value from JWT_SECRET
REFRESH_TOKEN_SECRET=replace-with-separate-64-plus-character-random-secret
# How long refresh tokens live (days). Default: 30
REFRESH_TOKEN_EXPIRES_DAYS=30

# CSRF protection (double-submit cookie pattern — required when using cookie auth)
# If not set, falls back to JWT_SECRET. Set a separate secret in production.
CSRF_SECRET=replace-with-separate-64-plus-character-random-secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Required for email verification. When SMTP_HOST is absent, verification URLs
# are logged to stdout (dev mode only — never use this in production).
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# EMAIL_FROM=noreply@yourdomain.com
# APP_URL=https://yourdomain.com   # used to build verification links in emails

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Frontend (React) ──────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# ── File uploads ──────────────────────────────────────────────────────────────
# STORAGE_PROVIDER=local   # "local" (default) or "s3"
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_MAX_FILES=10

# S3 / Cloudflare R2 (required when STORAGE_PROVIDER=s3)
# STORAGE_PROVIDER=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   # R2 only
# S3_PUBLIC_URL=https://cdn.yourdomain.com                    # optional CDN prefix
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ── Redis (required for horizontal scaling) ───────────────────────────────────
# REDIS_ENABLED=true
# REDIS_URL=redis://localhost:6379

# ── Sentry error tracking ─────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# SENTRY_ENVIRONMENT=production
# APP_VERSION=1.0.0

# Frontend Sentry (add to frontend/.env)
# REACT_APP_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# REACT_APP_ENV=production
# REACT_APP_VERSION=1.0.0

# ── Graceful shutdown ─────────────────────────────────────────────────────────
# SHUTDOWN_TIMEOUT_MS=10000

# ── Request timeout ───────────────────────────────────────────────────────────
# Requests exceeding this duration return 503. Set to 0 to disable.
# REQUEST_TIMEOUT_MS=30000

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info   # debug | info | warn | error
